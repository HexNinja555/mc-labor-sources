{
  "name": "mc-labor-sources",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mc-labor/admin-web dev",
    "mob": "pnpm --filter @mc-labor/mobile start",
    "build": "pnpm --filter @mc-labor/shared build && pnpm --filter @mc-labor/admin-web build",
    "clean": "node -e \"const fs=require('fs');['apps/admin-web/.next','packages/shared/dist'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true});console.log('removed',p)}catch(e){}})\"",
    "setup:check": "node scripts/check-supabase-env.mjs",
    "setup:db": "node scripts/check-supabase-env.mjs && node scripts/seed-auth-users.mjs",
    "seed:auth": "node scripts/seed-auth-users.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
